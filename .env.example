# ============================================================================
# MobilStock Environment Configuration
# ============================================================================

# Development Mode
VITE_ENV=development

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Frontend Settings
VITE_app_name=MobilStock
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_DEMO_MODE=true

# ============================================================================
# Backend (Node.js) Configuration (if running backend locally)
# ============================================================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=mobilstock_dev

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=7d

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. DO NOT commit this file to version control with real secrets
# 2. Create .env.local for local development (git-ignored)
# 3. Use secure secret managers for production (AWS Secrets Manager, HashiCorp Vault, etc.)
# 4. Rotate JWT_SECRET regularly
# 5. Use strong, unique DB_PASSWORD (min 16 chars, special chars)
# ============================================================================
